<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Darklock</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="icon" type="image/png" href="/platform/static/icons/darklock-guard.png" sizes="256x256">
    <style>
        :root {
            --bg-base: #06060b;
            --bg-surface: #0c0c14;
            --bg-elevated: #12121c;
            --bg-card: #161622;
            --text-primary: #f0f2f5;
            --text-secondary: #8b8fa3;
            --text-muted: #5c5f73;
            --accent: #6366f1;
            --accent-light: #818cf8;
            --accent-glow: rgba(99, 102, 241, 0.25);
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --border: rgba(255,255,255,0.06);
            --border-hover: rgba(255,255,255,0.12);
            --radius: 10px;
            --radius-lg: 16px;
            --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { -webkit-font-smoothing: antialiased; }
        body {
            font-family: var(--font);
            color: var(--text-primary);
            background: var(--bg-base);
            min-height: 100vh;
        }

        /* Nav */
        .dash-nav {
            position: sticky; top: 0; z-index: 100;
            background: rgba(6,6,11,0.85);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
            padding: 0 2rem;
        }
        .dash-nav-inner {
            max-width: 1280px; margin: 0 auto;
            display: flex; align-items: center; justify-content: space-between;
            height: 56px;
        }
        .dash-nav-brand {
            display: flex; align-items: center; gap: 0.6rem;
            text-decoration: none; color: var(--text-primary);
            font-weight: 700; font-size: 1.05rem;
        }
        .dash-nav-brand img { height: 28px; width: 28px; border-radius: 6px; }
        .dash-nav-brand .tag {
            font-size: 0.6rem; font-weight: 600;
            background: var(--accent); color: #fff;
            padding: 2px 6px; border-radius: 4px;
            text-transform: uppercase; letter-spacing: 0.5px;
        }
        .dash-nav-links { display: flex; gap: 0.25rem; }
        .dash-nav-links a {
            color: var(--text-secondary); text-decoration: none;
            padding: 0.4rem 0.75rem; border-radius: 6px;
            font-size: 0.85rem; font-weight: 500;
            transition: all 0.15s;
        }
        .dash-nav-links a:hover { color: var(--text-primary); background: rgba(255,255,255,0.04); }
        .dash-nav-links a.active { color: var(--accent-light); background: rgba(99,102,241,0.08); }
        .dash-nav-user {
            display: flex; align-items: center; gap: 0.75rem;
        }
        .dash-nav-user .username {
            font-size: 0.85rem; font-weight: 500;
            color: var(--text-secondary);
        }
        .dash-nav-user .avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), #8b5cf6);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.8rem; font-weight: 700; color: #fff;
        }
        .btn-logout {
            color: var(--text-muted); background: none; border: 1px solid var(--border);
            padding: 0.35rem 0.75rem; border-radius: 6px; font-size: 0.8rem;
            cursor: pointer; font-family: var(--font); transition: all 0.15s;
        }
        .btn-logout:hover { color: var(--danger); border-color: rgba(239,68,68,0.3); }

        /* Main content */
        .dash-main {
            max-width: 1280px; margin: 0 auto;
            padding: 2rem;
        }
        .dash-welcome { margin-bottom: 2rem; }
        .dash-welcome h1 {
            font-size: 1.75rem; font-weight: 700;
            margin-bottom: 0.25rem;
        }
        .dash-welcome h1 .name { color: var(--accent-light); }
        .dash-welcome p { color: var(--text-secondary); font-size: 0.95rem; }

        /* Stats grid */
        .dash-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1rem;
            margin-bottom: 2rem;
        }
        .dash-stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 1.25rem 1.5rem;
            position: relative; overflow: hidden;
        }
        .dash-stat-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0;
            height: 3px;
        }
        .dash-stat-card.accent::before { background: linear-gradient(90deg, var(--accent), #8b5cf6); }
        .dash-stat-card.success::before { background: linear-gradient(90deg, var(--success), #06b6d4); }
        .dash-stat-card.warning::before { background: linear-gradient(90deg, var(--warning), #f97316); }
        .dash-stat-card.info::before { background: linear-gradient(90deg, #06b6d4, var(--accent)); }
        .dash-stat-label {
            font-size: 0.78rem; font-weight: 500; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }
        .dash-stat-val {
            font-size: 2rem; font-weight: 800;
            line-height: 1;
        }
        .dash-stat-sub {
            font-size: 0.78rem; color: var(--text-secondary);
            margin-top: 0.35rem;
        }

        /* Quick actions */
        .dash-section-title {
            font-size: 1.1rem; font-weight: 700;
            margin-bottom: 1rem;
            display: flex; align-items: center; gap: 0.5rem;
        }
        .dash-section-title i { color: var(--accent-light); font-size: 0.9rem; }

        .dash-actions {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1rem;
            margin-bottom: 2.5rem;
        }
        .dash-action-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            transition: all 0.2s;
        }
        .dash-action-card:hover {
            border-color: var(--border-hover);
            transform: translateY(-2px);
        }
        .dash-action-icon {
            width: 40px; height: 40px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; margin-bottom: 0.75rem;
        }
        .dash-action-card h3 {
            font-size: 0.95rem; font-weight: 600;
            margin-bottom: 0.3rem;
        }
        .dash-action-card p {
            font-size: 0.82rem; color: var(--text-secondary);
            margin-bottom: 0.75rem; line-height: 1.5;
        }
        .dash-action-btn {
            display: inline-flex; align-items: center; gap: 0.4rem;
            font-size: 0.82rem; font-weight: 600; color: var(--accent-light);
            text-decoration: none; transition: color 0.15s;
        }
        .dash-action-btn:hover { color: #fff; }
        .dash-action-btn i { font-size: 0.7rem; }

        /* Account section */
        .dash-account {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-bottom: 2rem;
        }
        .dash-account-row {
            display: flex; justify-content: space-between; align-items: center;
            padding: 0.75rem 0;
            border-bottom: 1px solid var(--border);
        }
        .dash-account-row:last-child { border-bottom: none; }
        .dash-account-label { font-size: 0.82rem; color: var(--text-muted); font-weight: 500; }
        .dash-account-val { font-size: 0.9rem; font-weight: 500; }
        .dash-role-badge {
            font-size: 0.7rem; font-weight: 600;
            padding: 3px 8px; border-radius: 4px;
            text-transform: uppercase; letter-spacing: 0.5px;
        }
        .dash-role-badge.admin { background: rgba(239,68,68,0.12); color: #ef4444; }
        .dash-role-badge.user { background: rgba(99,102,241,0.12); color: var(--accent-light); }

        /* Footer */
        .dash-footer {
            text-align: center; padding: 2rem 0;
            color: var(--text-muted); font-size: 0.78rem;
            border-top: 1px solid var(--border);
        }
        .dash-footer a { color: var(--text-secondary); text-decoration: none; }
        .dash-footer a:hover { color: var(--accent-light); }

        @media (max-width: 768px) {
            .dash-main { padding: 1rem; }
            .dash-nav { padding: 0 1rem; }
            .dash-nav-links { display: none; }
            .dash-welcome h1 { font-size: 1.3rem; }
            .dash-stat-val { font-size: 1.5rem; }
        }
    </style>
</head>
<body>

<nav class="dash-nav">
    <div class="dash-nav-inner">
        <a href="/platform" class="dash-nav-brand">
            <img src="/platform/static/icons/darklock-logo.png" alt="Darklock">
            <span>Darklock</span>
            <span class="tag">Dashboard</span>
        </a>
        <div class="dash-nav-links">
            <a href="/platform/dashboard" class="active">Overview</a>
            <a href="/platform">Platform</a>
            <a href="/site/">Bot Info</a>
            <a href="/site/bug-reports" style="color:#f97316"><i class="fas fa-bug" style="margin-right:3px;font-size:.7rem"></i>Bugs</a>
        </div>
        <div class="dash-nav-user">
            <span class="username" id="dashUsername"></span>
            <div class="avatar" id="dashAvatar"></div>
            <button class="btn-logout" onclick="logout()"><i class="fas fa-sign-out-alt"></i> Logout</button>
        </div>
    </div>
</nav>

<main class="dash-main">
    <div class="dash-welcome">
        <h1>Welcome back, <span class="name" id="welcomeName">User</span></h1>
        <p>Here is an overview of your Darklock platform and bot status.</p>
    </div>

    <!-- Live Stats -->
    <div class="dash-stats">
        <div class="dash-stat-card accent">
            <div class="dash-stat-label">Active Servers</div>
            <div class="dash-stat-val" id="statServers">&mdash;</div>
            <div class="dash-stat-sub">Discord guilds protected</div>
        </div>
        <div class="dash-stat-card success">
            <div class="dash-stat-label">Users Protected</div>
            <div class="dash-stat-val" id="statUsers">&mdash;</div>
            <div class="dash-stat-sub">Total members across all servers</div>
        </div>
        <div class="dash-stat-card warning">
            <div class="dash-stat-label">Bot Uptime</div>
            <div class="dash-stat-val" id="statUptime">&mdash;</div>
            <div class="dash-stat-sub" id="statUptimeDetail">Since last restart</div>
        </div>
        <div class="dash-stat-card info">
            <div class="dash-stat-label">Platform Status</div>
            <div class="dash-stat-val" style="color:var(--success)"><i class="fas fa-circle" style="font-size:0.6em;margin-right:4px"></i>Online</div>
            <div class="dash-stat-sub" id="statPlatformTime"></div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="dash-section-title"><i class="fas fa-bolt"></i> Quick Actions</div>
    <div class="dash-actions">
        <div class="dash-action-card">
            <div class="dash-action-icon" style="background:rgba(99,102,241,0.1);color:var(--accent-light)">
                <i class="fas fa-plus"></i>
            </div>
            <h3>Add Bot to Server</h3>
            <p>Invite Darklock Security Bot to protect a new Discord server.</p>
            <a href="https://discord.com/api/oauth2/authorize?client_id=1439793800309379114&permissions=8&scope=bot%20applications.commands" target="_blank" class="dash-action-btn">
                <i class="fab fa-discord"></i> Add to Discord <i class="fas fa-arrow-right"></i>
            </a>
        </div>
        <div class="dash-action-card">
            <div class="dash-action-icon" style="background:rgba(34,197,94,0.1);color:var(--success)">
                <i class="fas fa-download"></i>
            </div>
            <h3>Darklock Guard</h3>
            <p>Download the enterprise file integrity protection app for your desktop.</p>
            <a href="/platform/download/darklock-guard" class="dash-action-btn">
                <i class="fas fa-shield-halved"></i> Download App <i class="fas fa-arrow-right"></i>
            </a>
        </div>
        <div class="dash-action-card">
            <div class="dash-action-icon" style="background:rgba(245,158,11,0.1);color:var(--warning)">
                <i class="fas fa-bug"></i>
            </div>
            <h3>Report a Bug</h3>
            <p>Found an issue? Help us improve by submitting a bug report.</p>
            <a href="/site/bug-reports" class="dash-action-btn">
                <i class="fas fa-flag"></i> Submit Report <i class="fas fa-arrow-right"></i>
            </a>
        </div>
        <div class="dash-action-card">
            <div class="dash-action-icon" style="background:rgba(6,182,212,0.1);color:#06b6d4">
                <i class="fas fa-book"></i>
            </div>
            <h3>Documentation</h3>
            <p>Learn about all features, commands, and configuration options.</p>
            <a href="/platform/docs" class="dash-action-btn">
                <i class="fas fa-file-lines"></i> View Docs <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </div>

    <!-- Account -->
    <div class="dash-section-title"><i class="fas fa-user-circle"></i> Account</div>
    <div class="dash-account">
        <div class="dash-account-row">
            <span class="dash-account-label">Username</span>
            <span class="dash-account-val" id="acctUsername">&mdash;</span>
        </div>
        <div class="dash-account-row">
            <span class="dash-account-label">Email</span>
            <span class="dash-account-val" id="acctEmail">&mdash;</span>
        </div>
        <div class="dash-account-row">
            <span class="dash-account-label">Role</span>
            <span class="dash-account-val" id="acctRole">&mdash;</span>
        </div>
        <div class="dash-account-row">
            <span class="dash-account-label">Profile</span>
            <a href="/platform/profile" class="dash-action-btn"><i class="fas fa-pen"></i> Edit Profile</a>
        </div>
    </div>
</main>

<footer class="dash-footer">
    <p>&copy; 2026 Darklock &mdash; <a href="/platform">Platform</a> &middot; <a href="/platform/privacy">Privacy</a> &middot; <a href="/platform/terms">Terms</a></p>
</footer>

<script>
(function() {
    'use strict';

    var user = window.DARKLOCK_USER;
    var stats = window.DARKLOCK_STATS || {};

    if (!user) {
        window.location.href = '/platform/auth/login?redirect=/platform/dashboard';
        return;
    }

    // Populate user info
    var displayName = user.displayName || user.username || 'User';
    document.getElementById('welcomeName').textContent = displayName;
    document.getElementById('dashUsername').textContent = displayName;
    document.getElementById('dashAvatar').textContent = (displayName[0] || 'U').toUpperCase();
    document.getElementById('acctUsername').textContent = user.username || '\u2014';
    document.getElementById('acctEmail').textContent = user.email || '\u2014';

    // Role badge
    var roleEl = document.getElementById('acctRole');
    var role = (user.role || 'user').toLowerCase();
    roleEl.innerHTML = '<span class="dash-role-badge ' + role + '">' + role + '</span>';

    // Populate injected stats
    if (stats.servers !== undefined) {
        document.getElementById('statServers').textContent = stats.servers;
    }
    if (stats.users !== undefined) {
        document.getElementById('statUsers').textContent = formatNum(stats.users);
    }
    if (stats.botUptime !== undefined && stats.botUptime > 0) {
        document.getElementById('statUptime').textContent = formatUptime(stats.botUptime);
    }
    document.getElementById('statPlatformTime').textContent = new Date().toLocaleString();

    // Refresh stats every 30s
    function refreshStats() {
        fetch('/api/stats').then(function(r) { return r.json(); }).then(function(d) {
            if (d.servers !== undefined) document.getElementById('statServers').textContent = d.servers;
            if (d.users !== undefined) document.getElementById('statUsers').textContent = formatNum(d.users);
            if (d.botUptime !== undefined && d.botUptime > 0) document.getElementById('statUptime').textContent = formatUptime(d.botUptime);
            document.getElementById('statPlatformTime').textContent = new Date().toLocaleString();
        }).catch(function() {});
    }
    setInterval(refreshStats, 30000);

    function formatNum(n) {
        if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
        if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
        return n.toString();
    }

    function formatUptime(seconds) {
        var d = Math.floor(seconds / 86400);
        var h = Math.floor((seconds % 86400) / 3600);
        var m = Math.floor((seconds % 3600) / 60);
        if (d > 0) return d + 'd ' + h + 'h';
        if (h > 0) return h + 'h ' + m + 'm';
        return m + 'm';
    }

    window.logout = function() {
        fetch('/platform/auth/logout', { method: 'POST', credentials: 'same-origin' }).then(function() {
            document.cookie = 'darklock_token=; expires=Thu, 01 Jan 1970 00:00:00 GMT; path=/';
            window.location.href = '/platform/auth/login';
        }).catch(function() {
            document.cookie = 'darklock_token=; expires=Thu, 01 Jan 1970 00:00:00 GMT; path=/';
            window.location.href = '/platform/auth/login';
        });
    };
})();
</script>

</body>
</html>
